APP_NAME="WhatsApp SuperBot"
NODE_ENV=development
BOT_PREFIX=.
OWNER_PHONE=6281234567890
ADMIN_PHONES=6281234567890

ENABLE_STICKER=true
ENABLE_DOWNLOADER=false
ENABLE_AI=true
ENABLE_GROUP_TOOLS=true
ENABLE_GAMES=true
ENABLE_UTILITY=true

MAX_MEDIA_SIZE_MB=15
MAX_VIDEO_DURATION_SECONDS=6

RATE_LIMIT_WINDOW_SECONDS=30
RATE_LIMIT_MAX_COMMANDS=8

DATABASE_DRIVER=sqlite
DATABASE_URL=file:./src/data/bot.sqlite

AI_PROVIDER=openrouter
AI_API_KEY=
AI_PRIMARY_MODEL=
AI_FALLBACK_MODEL=

CURRENCY_API_KEY=
WEATHER_API_KEY=
LYRIC_API_KEY=
QRIS_MERCHANT_NAME=Antoniqueee
QRIS_MERCHANT_CITY=JAKARTA
QRIS_MERCHANT_PHONE=
REDIS_URL=redis://localhost:6379
CHROME_EXECUTABLE_PATH=
